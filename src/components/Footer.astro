---
const today = new Date();
---

<footer>
	<nav class="footer-links" aria-label="フッターナビゲーション">
		<a href="/about/">運営者情報</a>
		<span class="sep" aria-hidden="true">/</span>
		<a href="/privacy-policy/">プライバシーポリシー</a>
		<span class="sep" aria-hidden="true">/</span>
		<a href="/legal/tokushou/">特定商取引法に基づく表記</a>
		<span class="sep" aria-hidden="true">/</span>
		<a href="/affiliate-policy/">アフィリエイトポリシー</a>
		<span class="sep" aria-hidden="true">/</span>
		<a href="/contact/">お問い合わせ</a>
	</nav>
	<div class="copyright">
		&copy; {today.getFullYear()} 対馬モーターサービス
	</div>
	<div class="social-links">
		<a href="https://www.instagram.com/kawatms/" target="_blank" rel="noopener">
			<span class="sr-only">Instagram @kawatms</span>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
				<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
				<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
			</svg>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: 0.4em 0.6em;
		margin-bottom: 1em;
		font-size: 0.9rem;
	}
	.footer-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.footer-links a:hover {
		color: rgb(var(--accent));
		text-decoration: underline;
	}
	.footer-links .sep {
		color: rgba(var(--gray), 0.6);
	}
	.copyright {
		margin-bottom: 0.5em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 600px) {
		.footer-links .sep {
			display: none;
		}
	}
</style>
