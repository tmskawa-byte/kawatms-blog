---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, CATEGORIES, getCategoryMeta } from '../../consts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return CATEGORIES.map((cat) => ({
		params: { category: cat.name },
		props: {
			category: cat,
			posts: posts
				.filter((p) => p.data.category === cat.name)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { category, posts } = Astro.props;
const meta = getCategoryMeta(category.name)!;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`${meta.emoji} ${meta.name} | ${SITE_TITLE}`}
			description={`カテゴリ: ${meta.name} — ${meta.description}`}
		/>
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}
			.header {
				margin-bottom: 1.5em;
			}
			.header h1 {
				margin: 0;
			}
			.header .desc {
				color: rgb(var(--gray));
				margin: 0.25em 0 0 0;
			}
			.breadcrumb {
				margin-bottom: 0.5em;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
			}
			ul.posts {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul.posts li {
				padding: 1em 0;
				border-bottom: 1px solid rgba(var(--gray), 0.2);
			}
			ul.posts a {
				display: block;
				text-decoration: none;
				color: rgb(var(--black));
				transition: 0.2s ease;
			}
			ul.posts a:hover .title {
				color: rgb(var(--accent));
			}
			ul.posts .title {
				font-size: 1.25rem;
				font-weight: 700;
				margin: 0 0 0.25rem 0;
			}
			ul.posts .date {
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}
			.empty {
				color: rgb(var(--gray));
				padding: 2em 0;
				text-align: center;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="breadcrumb">
				<a href="/categories/">カテゴリ一覧</a> /
			</div>
			<div class="header">
				<h1>{meta.emoji} {meta.name}</h1>
				<p class="desc">{meta.description}</p>
			</div>
			{posts.length === 0 ? (
				<p class="empty">このカテゴリの記事はまだありません。</p>
			) : (
				<ul class="posts">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h2 class="title">{post.data.title}</h2>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
